-- Q: Show employees earning MORE than company average salary.

-- ❌ My attempt (AVG can't be used directly in WHERE!)
SELECT name, salary
FROM employees
WHERE salary > AVG(salary);

-- ✅ Correct version
SELECT name, salary
FROM employees
WHERE salary > (SELECT AVG(salary) FROM employees);

-- 💡 Why: At WHERE stage, SQL hasn't calculated AVG yet!
--         Subquery runs FIRST, returns the number,
--         THEN WHERE compares against it!

-- Q: Show employees working in departments located in Pune.

-- ❌ My attempt (wrong operators!)
SELECT e.name, d.dept_name
FROM employees e
WHERE e.dept_id == d.dept_id
&& d.location = 'Pune';

-- ✅ Correct version (Subquery approach)
SELECT e.name
FROM employees e
WHERE e.dept_id IN (
    SELECT dept_id
    FROM departments
    WHERE location = 'Pune'
);

-- ✅ Alternative (JOIN approach)
SELECT e.name, d.dept_name
FROM employees e
JOIN departments d ON e.dept_id = d.dept_id
WHERE d.location = 'Pune';

-- 💡 SQL vs Other Languages:
-- ==   →  =      (single equals in SQL)
-- &&   →  AND    (keyword not symbol)
-- ||   →  OR     (keyword not symbol)

-- Q: Show employees NOT assigned to ANY project yet.

-- ❌ My attempt 1 (wrong table in subquery!)
SELECT e.emp_id, e.name
FROM employees e
WHERE e.emp_id NOT IN (
    SELECT project_id FROM projects  -- ❌ wrong table!
);

-- ❌ My attempt 2 (wrong JOIN syntax!)
SELECT e.emp_id, e.name
FROM employees e, projects p
LEFT JOIN e.emp_id = p.project_id;  -- ❌ missing table name!

-- ✅ Correct version (NOT IN approach)
SELECT e.emp_id, e.name
FROM employees e
WHERE e.emp_id NOT IN (
    SELECT emp_id FROM emp_projects  -- ✅ bridge table!
    WHERE emp_id IS NOT NULL         -- safety for NULLs!
);

-- ✅ Alternative (LEFT JOIN + IS NULL)
SELECT e.emp_id, e.name
FROM employees e
LEFT JOIN emp_projects ep ON e.emp_id = ep.emp_id
WHERE ep.emp_id IS NULL;

-- ✅ Alternative (NOT EXISTS — interview favourite!)
SELECT emp_id, name FROM employees e
WHERE NOT EXISTS (
    SELECT 1 FROM emp_projects ep
    WHERE ep.emp_id = e.emp_id
);

-- 💡 When to use which:
-- Small data  → NOT IN (readable)
-- Large data  → LEFT JOIN IS NULL (fastest!)
-- Interviews  → NOT EXISTS (shows expertise!)